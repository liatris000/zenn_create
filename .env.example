# Liatris zenn_create リポジトリで使用する環境変数のサンプル
# このファイル (.env.example) はcommit対象。実際の値は .env (gitignore済) に書く

# ─── GitHub ───
# personal access token (repo, workflow スコープ)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# ─── Chatwork ───
# Chatwork API token: https://www.chatwork.com/service/packages/chatwork/subpackages/api/token.php
CHATWORK_API_TOKEN=xxxxxxxx
# 通知先のルームID (URLの #!rid123456789 の数字部分)
CHATWORK_ROOM_ID=123456789
# メンション対象のアカウントID (省略可)
CHATWORK_ACCOUNT_ID=9876543

# ─── Zenn記事の冒頭リンク ───
# 設計記事 (note) のURL
DESIGN_ARTICLE_URL=https://note.com/liatris000/n/xxxxxxxx
