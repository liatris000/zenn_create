# Liatris zenn_create リポジトリで使用する環境変数のサンプル
# このファイル (.env.example) はcommit対象。実際の値は .env (gitignore済) に書く

# ─── GitHub ───
# personal access token (repo, workflow スコープ)
GITHUB_TOKEN=ghp_REPLACE_WITH_YOUR_TOKEN

# (任意) 操作対象のGitHubユーザー。デフォルト: liatris000
# fork した場合などはここで上書き可能
# GITHUB_USER=your-github-username

# ─── Chatwork ───
# Chatwork API token: https://www.chatwork.com/service/packages/chatwork/subpackages/api/token.php
CHATWORK_API_TOKEN=REPLACE_WITH_YOUR_API_TOKEN
# 通知先のルームID (URLの #!rid〜 の数字部分)
CHATWORK_ROOM_ID=YOUR_ROOM_ID
# メンション対象のアカウントID (省略可)
CHATWORK_ACCOUNT_ID=YOUR_ACCOUNT_ID

# ─── Zenn記事の冒頭リンク ───
# 設計記事 (note) のURL
DESIGN_ARTICLE_URL=https://note.com/YOUR_ACCOUNT/n/YOUR_ARTICLE_ID
